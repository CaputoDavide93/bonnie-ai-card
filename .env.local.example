# Copy to .env.local and fill in. .env.local is gitignored.

# SSH target of your Home Assistant instance
HA_SSH=root@192.168.1.10

# HA base URL
HA_URL=http://192.168.1.10:8123

# HA long-lived access token (Profile → Security → Long-Lived Access Tokens)
# Needed to trigger the HA restart after each card upload.
HA_TOKEN=

# Optional: path inside HA to upload the card to (default: /config/www/bonnie-ai-card.js)
# CARD_PATH=/config/www/bonnie-ai-card.js
